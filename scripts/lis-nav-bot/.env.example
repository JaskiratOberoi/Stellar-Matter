# Copy to .env and fill in. Used by lis-nav-bot (read-only).

# Primary LIS login URL (fallback backup can be set in code if needed)
# Example from Listec CBC stack:
# LIS_TARGET_URL=http://122.161.198.159:88/login.aspx
LIS_TARGET_URL=

# Login (same convention as CBC: dedicated vars, not committed)
LIS_LOGIN_USERNAME=
LIS_LOGIN_PASSWORD=

# Optional: use system Chrome/Chromium (otherwise Puppeteer downloads Chromium)
# LIS_CHROMIUM_EXECUTABLE_PATH=C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe

# Default headful for debugging; override with --headless
# LIS_HEADLESS=false

# Safety: this read-only bot exits if set to 1 (reserved for a future write-capable variant)
# LIS_ALLOW_WRITES=0
