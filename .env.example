# --- Server bind ---------------------------------------------------------
# Container listens on 4378 by default; host port comes from MATTER_APP_PORT below.
# When running `node server/index.js` outside Docker, set LIS_UI_PORT to the
# port you actually want (legacy default is 4377).
MATTER_APP_PORT=4378
# LIS_UI_PORT=4377    # legacy default for `npm run dev:server` outside Docker
# LIS_UI_HOST=127.0.0.1

# --- Database ------------------------------------------------------------
# Required for auth + admin panel + Postgres-backed run history. Without it
# the app degrades to legacy single-user mode and never asks for a login.
DATABASE_URL=postgresql://matter:matter@localhost:5434/matter
# MATTER_DB_USER=matter
# MATTER_DB_PASSWORD=matter
# MATTER_DB_NAME=matter
# MATTER_DB_PORT=5434      # host port for the Postgres container

# --- JWT secret ----------------------------------------------------------
# Required in production (NODE_ENV=production refuses to start without it).
JWT_SECRET=change-me-in-production

# --- Super-admin seed (consumed once on first migrate) ------------------
# server/db/migrate.js inserts a super_admin row only when this username
# does not already exist; password is bcrypt-hashed at cost 10.
SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_PASSWORD=ChangeMeBeforeFirstBoot
SUPER_ADMIN_DISPLAY_NAME=Super Admin

# --- CORS for cross-origin SPA -------------------------------------------
# Comma-separated. The Hostinger-hosted SPA (matter.stellarinfomatica.com)
# calls api-matter.stellarinfomatica.com (this host via Caddy) — that
# origin needs to be listed here. Same-origin Docker doesn't strictly need
# CORS but the value is harmless.
CORS_ORIGINS=https://matter.stellarinfomatica.com

# --- Listec service ------------------------------------------------------
# Inside Docker we use host.docker.internal so the container can reach the
# Listec API running on the host. Outside Docker, point at the LAN address.
LISTEC_API_BASE_URL=http://127.0.0.1:3100

# --- Hostinger DNS automation (used by scripts/hostinger-dns.js) --------
# Phase 6 — paste your Hostinger Developer API key here.
# HOSTINGER_API_KEY=

# --- Misc ----------------------------------------------------------------
# Timezone for any cron / log timestamps in the container.
TZ=Asia/Kolkata
# Override the Chromium binary for the Puppeteer-based scrape source.
# LIS_CHROMIUM_EXECUTABLE_PATH=/usr/bin/chromium
