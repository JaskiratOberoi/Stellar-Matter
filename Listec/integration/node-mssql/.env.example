# Listec SQL — environment template for Node.js (mssql)
# Copy to .env in your app root (never commit .env).

LISTEC_SQL_SERVER=your-server.database.windows.net
# Or: LISTEC_SQL_SERVER=122.161.198.159,1433

LISTEC_SQL_DATABASE=Noble
LISTEC_SQL_USER=listec_ro
# Temporary local inspection only: you may use a high-privilege SQL login (e.g. nobleone) in
# Listec/.env to run `npm run inspect:sales` — then remove it and restore listec_ro. Never commit
# passwords or ship nobleone in Docker/production.
LISTEC_SQL_PASSWORD=replace-me

# ODBC Driver 18 style defaults (recommended for Azure SQL; also works for on-prem with cert)
LISTEC_SQL_ENCRYPT=true
LISTEC_SQL_TRUST_CERT=true

LISTEC_SQL_APP_NAME=ListecWorksheetReport
LISTEC_SQL_CONNECT_TIMEOUT_MS=15000
LISTEC_SQL_REQUEST_TIMEOUT_MS=120000

# example.express.ts — HTTP bind (defaults in code: host 0.0.0.0, port 3100)
# LISTEC_API_HOST=127.0.0.1   # optional: localhost-only; omit for Docker + host.docker.internal
LISTEC_API_PORT=3100

# --- Tracer: Sales & Marketing users (listec.salesUsers.ts) -----------------
# Run `npm run inspect:sales` (from this folder) after pointing Listec/.env at Noble to dump
# real dbo table/column names for the keys below. Auto-discovery reads sys.foreign_keys.
# If you see "User table has no UserTypeId FK and no inline UserType", set explicit tables/columns
# (names must match dbo tables in Noble SQL Server):
#
# Required: user↔MCC mapping + user PK
# LISTEC_SALES_USER_TABLE=tbl_your_user
# LISTEC_SALES_USER_PK=id
# LISTEC_SALES_MAP_TABLE=tbl_your_user_mcc_map
# LISTEC_SALES_MAP_USER_COL= MCUUserId
# LISTEC_SALES_MAP_MCC_COL= MCCUnitId
#
# MCC master (defaults match Noble Med MCC master if unset)
# LISTEC_SALES_MCC_TABLE=tbl_med_mcc_unit_master
# LISTEC_SALES_MCC_PK=id
# LISTEC_SALES_MCC_CODE_COL=MCCUnitCode
#
# How to restrict to "Sales and Marketing" — use ONE of:
# (A) FK to a type master row whose name column equals "Sales and Marketing" (case-insensitive)
# LISTEC_SALES_USER_TYPE_FK_COL=UserTypeId
# LISTEC_SALES_TYPE_TABLE=tbl_your_user_type
# LISTEC_SALES_TYPE_PK=id
# LISTEC_SALES_TYPE_NAME_COL=Name
# (B) A column on the user row that stores that phrase (exact match after trim)
# LISTEC_SALES_USER_TYPE_INLINE_COL=Designation
#
# Optional display columns for chip labels:
# LISTEC_SALES_FIRST_NAME_COL=FirstName
# LISTEC_SALES_LAST_NAME_COL=LastName
# LISTEC_SALES_USER_NAME_COL=UserName
