# Local SPA + Docker backend: run `docker compose up -d` then `npm run dev:web-docker`
# (same as dev:web). Vite proxies /api → MATTER_APP_PORT (Docker app listens on 4378).
#
# Docker Compose publishes Matter on host port 4378 (see docker-compose.yml).
MATTER_APP_PORT=4378
# For a fully local API (`npm run dev` with Node on 4377), use: MATTER_APP_PORT=4377
#
# Uncomment only if you intentionally want the SPA to call a remote API (CORS must allow it):
# VITE_API_BASE_URL=https://api-matter.stellarinfomatica.com
